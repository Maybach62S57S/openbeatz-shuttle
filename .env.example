# ==== Flug-Tracking (serverseitig, NICHT ins Frontend) ====
# AeroDataBox über RapidAPI: https://rapidapi.com/aedbx-aedbx/api/aerodatabox
AERODATABOX_API_KEY=dein_rapidapi_key
AERODATABOX_API_HOST=aerodatabox.p.rapidapi.com
# Zielflughafen für die Ankunftsauswahl (IATA)
ARRIVAL_AIRPORT_IATA=NUE

# ==== Optionaler zweiter Provider / Fallback (noch nicht implementiert) ====
# FLIGHTAWARE_API_KEY=dein_aeroapi_key

# ==== Supabase (siehe supabaseStore.js / supabase-schema.sql) ====
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...

# ==== Chat-Assistent (serverseitig, NIE ins Frontend, siehe api/chat.js) ====
# Eigener Anthropic-API-Key, z. B. von console.anthropic.com
ANTHROPIC_API_KEY=dein_anthropic_api_key

# ==== Web Push / echte Benachrichtigungen (serverseitig, NIE ins Frontend) ====
# Einmalig erzeugen: npx web-push generate-vapid-keys
# Public Key zusätzlich in der App unter Einstellungen -> Push-Benachrichtigungen eintragen.
VAPID_PUBLIC_KEY=dein_vapid_public_key
VAPID_PRIVATE_KEY=dein_vapid_private_key
VAPID_SUBJECT=mailto:info@merg-and-more.ch
# api/send-push.js braucht direkten DB-Zugriff (Service Role, nicht die anon-Key von oben):
SUPABASE_URL=...
SUPABASE_SERVICE_ROLE_KEY=...

# ==== API-Absicherung für api/chat.js & api/send-push.js (Nachtrag 3) ====
# Beides optional, aber empfohlen. Kein vollwertiges Auth (siehe BACKEND-
# README), verhindert aber automatisiertes/wildes Fremdnutzen der beiden
# öffentlich erreichbaren Endpoints.
# Eure echte Vercel-Domain(s), kommagetrennt, ohne trailing slash:
ALLOWED_APP_ORIGIN=https://euer-projekt.vercel.app
# Frei gewählter String, muss serverseitig UND clientseitig identisch gesetzt
# werden (deshalb zwei Variablen mit demselben Wert). Landet zwangsläufig im
# JS-Bundle, ist also kein echtes Geheimnis, nur eine zusätzliche Hürde.
INTERNAL_API_SECRET=irgendein_langer_zufaelliger_string
VITE_INTERNAL_API_SECRET=irgendein_langer_zufaelliger_string

# ==== Google Maps (Live-Karte mit echtem Fahrer-GPS, optional) ====
# Bewusst clientseitig (VITE_-Prefix) - das ist bei Google Maps so vorgesehen,
# der Key wird über HTTP-Referrer-Einschränkung in der Google Cloud Console
# auf eure Domain(s) beschränkt, nicht über Geheimhaltung. Ohne gesetzten Key
# bleibt die App bei der kostenlosen Schema-Karte (kein Fehler, kein Zwang).
# Einrichtung: console.cloud.google.com -> Projekt anlegen -> Billing aktivieren
# (Pflicht, auch im Freikontingent) -> "Maps JavaScript API" aktivieren ->
# API-Key erzeugen -> unter "Application restrictions" auf HTTP-Referrer eurer
# Vercel-Domain(s) einschränken, unter "API restrictions" nur auf "Maps
# JavaScript API" beschränken.
VITE_GOOGLE_MAPS_API_KEY=dein_google_maps_key

