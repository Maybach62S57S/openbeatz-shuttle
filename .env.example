# ==== Flug-Tracking (serverseitig, NICHT ins Frontend) ====
# AeroDataBox über RapidAPI: https://rapidapi.com/aedbx-aedbx/api/aerodatabox
AERODATABOX_API_KEY=dein_rapidapi_key
AERODATABOX_API_HOST=aerodatabox.p.rapidapi.com
# Zielflughafen für die Ankunftsauswahl (IATA)
ARRIVAL_AIRPORT_IATA=NUE

# ==== Optionaler zweiter Provider / Fallback (noch nicht implementiert) ====
# FLIGHTAWARE_API_KEY=dein_aeroapi_key

# ==== Supabase (siehe supabaseStore.js / supabase-schema.sql) ====
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...

# ==== Chat-Assistent (serverseitig, NIE ins Frontend, siehe api/chat.js) ====
# Eigener Anthropic-API-Key, z. B. von console.anthropic.com
ANTHROPIC_API_KEY=dein_anthropic_api_key

# ==== Web Push / echte Benachrichtigungen (serverseitig, NIE ins Frontend) ====
# Einmalig erzeugen: npx web-push generate-vapid-keys
# Public Key zusätzlich in der App unter Einstellungen -> Push-Benachrichtigungen eintragen.
VAPID_PUBLIC_KEY=dein_vapid_public_key
VAPID_PRIVATE_KEY=dein_vapid_private_key
VAPID_SUBJECT=mailto:info@merg-and-more.ch
# api/send-push.js braucht direkten DB-Zugriff (Service Role, nicht die anon-Key von oben):
SUPABASE_URL=...
SUPABASE_SERVICE_ROLE_KEY=...

